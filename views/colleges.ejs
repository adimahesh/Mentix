<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/header", { title: "Government Colleges - Career Advisor" }) %>
</head>
<body class="flex flex-col min-h-screen bg-gray-50 font-sans">

  <%- include("partials/navbar") %>

  
  <main class="flex-grow max-w-7xl mx-auto px-6 py-11">
    
    
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-10 gap-4">
      <h1 class="text-4xl font-bold text-gray-800"> Government Colleges</h1>
      <form class="flex w-full md:w-auto gap-2" method="GET" action="/colleges">
        <input
          type="text"
          name="location"
          placeholder=" Search by location"
          value="<%= typeof req !== 'undefined' ? (req.query.location || '') : '' %>"
          class="flex-grow px-4 py-2 rounded-lg border border-gray-300 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
        >
        <button 
          type="submit"
          class="px-6 py-2 bg-indigo-600 text-white font-medium rounded-lg shadow hover:bg-indigo-700 transition">
          Search
        </button>
      </form>
    </div>

    
    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-8">
      
     
            <% ["Engineering","Medical","Commerce","Arts"].forEach(c => { %>
              <label class="flex items-center gap-2 text-gray-600">
                <input type="checkbox" name="courses" value="<%= c %>"
                  <%= req.query.courses && req.query.courses.includes(c) ? "checked" : "" %>> <%= c %>
              </label>
            <% }) %>
          </div>

          <div>
            <h3 class="font-medium text-gray-700 mb-2">Facilities</h3>
            <% ["Library","Hostel","Sports","Labs"].forEach(f => { %>
              <label class="flex items-center gap-2 text-gray-600">
                <input type="checkbox" name="facilities" value="<%= f %>"
                  <%= req.query.facilities && req.query.facilities.includes(f) ? "checked" : "" %>> <%= f %>
              </label>
            <% }) %>
          </div>

          <button type="submit" class="w-full py-2 text-indigo-600 border border-indigo-600 rounded-lg font-semibold hover:bg-indigo-50 transition">
            Apply Filters
          </button>
        </form>
      </aside> -->

      
      <section class="md:col-span-2 lg:col-span-3 grid grid-cols-1 gap-6">
        <% if (colleges.length === 0) { %>
          <p class="text-gray-600 text-lg">No colleges found. Try another search or filter.</p>
        <% } else { %>
          <% colleges.forEach(col => { %>
            <div class="bg-white rounded-xl shadow hover:shadow-xl transition p-6">
              <h3 class="text-lg font-semibold text-indigo-600 hover:text-indigo-800 mb-1">
                <a href="/colleges?selected=<%= col.id %><%= req.query.location ? '&location='+req.query.location : '' %>">
                  <%= col.name %>
                </a>
              </h3>
              <p class="text-gray-500 text-sm"> <%= col.university %></p>
              <p class="text-gray-500 text-sm"> <%= col.district %>, <%= col.state %></p>
              <p class="text-gray-700 text-sm"><strong>Type:</strong> <%= col.type %></p>
            </div>
          <% }) %>
        <% } %>
      </section>

      
     <aside class="md:col-span-1 lg:col-span-2 bg-white p-6 rounded-xl shadow-md
             w-full max-w-md h-[500px] overflow-y-auto">
  <% if (selectedCollege) { %>
    <h2 class="text-2xl font-bold text-indigo-700 mb-3"><%= selectedCollege.name %></h2>
    <p class="text-gray-600 mb-2"> <strong>University:</strong> <%= selectedCollege.university %></p>
    <p class="text-gray-600 mb-2"> <strong>Type:</strong> <%= selectedCollege.type %></p>
    <p class="text-gray-600 mb-2"> <strong>District:</strong> <%= selectedCollege.district %></p>
    <p class="text-gray-600 mb-2"> <strong>State:</strong> <%= selectedCollege.state %></p>
  <% } else { %>
    <p class="text-gray-500"> Select a college to view its details.</p>
  <% } %>
</aside>


    </div>
  </main>

  
  <footer class="bg-gray-100 text-gray-600 text-center">
    <%- include("partials/footer") %>
  </footer>

</body>
</html>
